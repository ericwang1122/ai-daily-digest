# ── Vercel Blob ──────────────────────────────────────────────────────────────
# Auto-provisioned when you add Vercel Blob via the dashboard or CLI.
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxx

# ── Auth ─────────────────────────────────────────────────────────────────────
# Password for the /admin page
ADMIN_SECRET=your-admin-password-here

# Secret for the /api/digest/push endpoint (used by local push script)
PUSH_SECRET=your-push-secret-here

# Auto-provisioned by Vercel for cron job auth
CRON_SECRET=

# ── AI Generation (server-side cron) ─────────────────────────────────────────
# Used when the Vercel Cron auto-generates digests.
# Not needed if you only use the local push script.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx
